---
import Base from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { site, services, steps, problems } from '../siteConfig.js';
const compare = [
  { point:"You own the site, domain & code", us:true, them:false },
  { point:"No markup on your ad spend", us:true, them:false },
  { point:"No monthly platform hostage fees", us:true, them:false },
  { point:"Built to load in under a second", us:true, them:false },
  { point:"Free Web Presence Report Card", us:true, them:false },
];
---
<Base path="/">
  <!-- HERO -->
  <section style="background:var(--navy);color:var(--cream);padding-bottom:48px">
    <div class="wrap hero">
      <div class="hero-copy">
        <p class="label">Web presence for Tampa Bay trades</p>
        <h1 style="margin-top:14px">Build like an A.<br/>Show up online like one.</h1>
        <p style="margin-top:20px;max-width:46ch;font-size:1.12rem;opacity:.9">
          You do great work. But if your website is slow, thin, or stuck on a platform you don't own,
          homeowners never see it. We build the web presence your reputation already earned — and you
          own every piece of it.
        </p>
        <div style="margin-top:30px;display:flex;gap:14px;flex-wrap:wrap">
          <a class="btn" href="/contact/">Get your free Report Card</a>
          <a class="btn btn-ghost" style="border-color:var(--gold);color:var(--gold)" href="/pricing/">See pricing</a>
        </div>
        <p style="margin-top:26px;opacity:.7;font-size:.95rem">Trusted by Tampa Bay trades & home-service contractors.</p>
      </div>
      <div class="hero-img">
        <img src="/images/hero.webp" width="853" height="476" alt="A fast, modern contractor website shown on a laptop and phone, built by Foundations" loading="eager" />
      </div>
    </div>
  </section>

  <!-- STATS BAND -->
  <section class="stats" style="padding:0">
    <div class="wrap">
      <div class="statrow">
        <div class="stat">
          <span class="statnum">8</span>
          <span class="statlbl">Dimensions we grade<br/>on your Report Card</span>
        </div>
        <div class="stat">
          <span class="statnum">100<span class="pct">%</span></span>
          <span class="statlbl">Ownership — the site<br/>and assets are yours</span>
        </div>
        <div class="stat">
          <span class="statnum">0<span class="pct">%</span></span>
          <span class="statlbl">Markup on your<br/>ad spend, ever</span>
        </div>
        <div class="stat">
          <span class="statnum">&lt;1<span class="pct">s</span></span>
          <span class="statlbl">Page load — fast<br/>enough to rank</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section>
    <div class="wrap">
      <p class="label">What we do</p>
      <h2 style="margin-top:10px">Everything to get found, and chosen.</h2>
      <div class="grid g3" style="margin-top:36px">
        {services.map(s => (
          <a class="card svc" href={`/services/${s.slug}/`}>
            <span class="ico"><Icon name={s.icon} /></span>
            <h3 style="font-size:1.12rem;margin-top:14px">{s.title}{s.addon && <span class="pill">Add-on</span>}</h3>
            <p style="margin-top:10px;color:var(--muted)">{s.blurb}</p>
            <p style="margin-top:14px" class="label">Learn more →</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section style="background:#fff;border-top:1px solid var(--line);border-bottom:1px solid var(--line)">
    <div class="wrap">
      <p class="label">How it works</p>
      <h2 style="margin-top:10px">Three steps to a foundation that compounds.</h2>
      <div class="grid g3" style="margin-top:40px">
        {steps.map(st => (
          <div>
            <span class="stepn">{st.n}</span>
            <h3 style="font-size:1.2rem;margin-top:12px">{st.title}</h3>
            <p style="margin-top:10px;color:var(--muted)">{st.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COMPARISON -->
  <section>
    <div class="wrap" style="max-width:760px">
      <p class="label" style="text-align:center">The difference</p>
      <h2 style="margin-top:10px;text-align:center;max-width:22ch;margin-inline:auto">Most agencies rent you a presence. We hand you one.</h2>
      <div class="comp" style="margin-top:36px">
        <div class="comp-head">
          <span></span>
          <span class="comp-us">Foundations</span>
          <span class="comp-them">Most agencies</span>
        </div>
        {compare.map(c => (
          <div class="comp-row">
            <span>{c.point}</span>
            <span class="comp-us">{c.us ? "✓" : "—"}</span>
            <span class="comp-them">{c.them ? "✓" : "—"}</span>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- PROBLEM -> FIX -->
  <section style="background:var(--cream)">
    <div class="wrap">
      <p class="label">Sound familiar?</p>
      <h2 style="margin-top:10px">The problems we hear — and how we fix them.</h2>
      <div class="grid g3" style="margin-top:36px">
        {problems.map(pr => (
          <div class="card prob">
            <p class="prob-pain">&ldquo;{pr.pain}&rdquo;</p>
            <p class="prob-fix"><span class="prob-fix-lbl">How we fix it:</span> {pr.fix}</p>
          </div>
        ))}
      </div>
      <p style="text-align:center;margin-top:30px;font-size:1.2rem;font-family:var(--display);font-weight:800">
        Marketing should grow your business — <span style="color:var(--brass)">not your stress level.</span>
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:var(--navy);color:var(--cream);text-align:center">
    <div class="wrap">
      <h2 style="max-width:18ch;margin-inline:auto">See exactly where your web presence stands.</h2>
      <p style="margin-top:16px;opacity:.9;max-width:46ch;margin-inline:auto">
        We grade it A–F across 8 dimensions — free, no obligation. Most contractors are shocked.
      </p>
      <a class="btn" style="margin-top:28px" href="/contact/">Get your free Report Card</a>
    </div>
  </section>

  <style>
    .stats{background:var(--cream);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
    .statrow{display:grid;grid-template-columns:repeat(2,1fr);gap:0}
    @media(min-width:760px){.statrow{grid-template-columns:repeat(4,1fr)}}
    .stat{padding:34px 24px;text-align:center;border-right:1px solid var(--line);border-bottom:1px solid var(--line)}
    @media(min-width:760px){.stat{border-bottom:none}.stat:last-child{border-right:none}}
    .stat:nth-child(2n){border-right:none}
    @media(min-width:760px){.stat:nth-child(2n){border-right:1px solid var(--line)}}
    .statnum{display:block;font-family:var(--display);font-weight:800;font-size:2.8rem;line-height:1;color:var(--navy);letter-spacing:-.02em}
    .statnum .pct{color:var(--brass);font-size:1.6rem;vertical-align:super}
    .statlbl{display:block;margin-top:12px;font-size:.82rem;color:var(--muted);line-height:1.45}
    .hero{display:grid;gap:40px;align-items:center;padding-top:24px}
    @media(min-width:880px){.hero{grid-template-columns:1.05fr .95fr}}
    .hero-img img{width:100%;height:auto;border-radius:14px;box-shadow:0 24px 60px rgba(0,0,0,.35)}
    
    .svc .ico{display:inline-flex;align-items:center;justify-content:center;width:48px;height:48px;border-radius:10px;background:var(--cream);color:var(--brass)}
    .svc:hover .ico{background:var(--gold);color:var(--navy)}
    .pill{display:inline-block;margin-left:8px;font-family:var(--mono);font-size:.6rem;letter-spacing:.08em;text-transform:uppercase;color:var(--brass);border:1px solid var(--gold);border-radius:20px;padding:2px 8px;vertical-align:middle}
    .stepn{font-family:var(--display);font-weight:800;font-size:2.4rem;color:var(--gold);-webkit-text-stroke:1px var(--brass)}
    .comp{border:1px solid var(--line);border-radius:14px;overflow:hidden;background:#fff}
    .comp-head,.comp-row{display:grid;grid-template-columns:1fr 130px 130px;align-items:center}
    .comp-head{background:var(--navy);color:var(--cream);padding:14px 20px;font-family:var(--mono);font-size:.72rem;text-transform:uppercase;letter-spacing:.08em}
    .comp-row{padding:16px 20px;border-top:1px solid var(--line)}
    .comp-us{text-align:center;color:var(--brass);font-weight:800}
    .comp-them{text-align:center;color:var(--muted)}
    .comp-head .comp-us{color:var(--gold)} .comp-head .comp-them{color:var(--cream);opacity:.7}
    @media(max-width:620px){.comp-head,.comp-row{grid-template-columns:1fr 64px 64px}}
    .prob{display:flex;flex-direction:column}
    .prob-pain{font-family:var(--display);font-weight:800;font-size:1.05rem;font-style:italic;color:var(--navy);line-height:1.3}
    .prob-fix{margin-top:14px;color:var(--muted);font-size:.92rem;padding-top:14px;border-top:1px solid var(--line)}
    .prob-fix-lbl{color:var(--brass);font-weight:700}
  </style>
</Base>
