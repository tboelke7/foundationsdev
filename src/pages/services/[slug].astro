---
import Base from '../../layouts/BaseLayout.astro';
import { services } from '../../siteConfig.js';
export function getStaticPaths() {
  return services.map(s => ({ params: { slug: s.slug }, props: { service: s } }));
}
const { service } = Astro.props;
const others = services.filter(s => s.slug !== service.slug).slice(0,3);
---
<Base title={service.title} description={service.blurb} path={`/services/${service.slug}/`}>
  <section style="background:var(--navy);color:var(--cream);padding:56px 0">
    <div class="wrap">
      <p class="label">Service{service.addon ? " · Add-on" : ""}</p>
      <h1 style="margin-top:12px;max-width:20ch">{service.title}</h1>
      <p style="margin-top:16px;max-width:54ch;font-size:1.12rem;opacity:.9">{service.blurb}</p>
    </div>
  </section>

  <section>
    <div class="wrap svc-detail">
      <div class="svc-media">
        <img src={service.image} alt={service.title} width="640" height="560" loading="eager"
             onerror="this.classList.add('ph')" />
      </div>
      <div class="svc-body">
        <p style="font-size:1.1rem;color:var(--ink)">{service.intro}</p>
        <p class="label" style="margin-top:28px">What's included</p>
        <ul class="svc-list">
          {service.points.map(pt => <li>{pt}</li>)}
        </ul>
        <div style="margin-top:32px;display:flex;gap:12px;flex-wrap:wrap">
          <a class="btn" href="/contact/">Get your free Report Card</a>
          <a class="btn btn-ghost" href="/pricing/">See pricing</a>
        </div>
      </div>
    </div>
  </section>

  <section style="background:var(--cream);border-top:1px solid var(--line)">
    <div class="wrap">
      <p class="label">More services</p>
      <div class="grid g3" style="margin-top:24px">
        {others.map(o => (
          <a class="card" href={`/services/${o.slug}/`}>
            <h3 style="font-size:1.1rem">{o.title}</h3>
            <p style="margin-top:8px;color:var(--muted)">{o.tease}</p>
            <p style="margin-top:12px" class="label">Learn more →</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <style>
    .svc-detail{display:grid;gap:44px;align-items:start}
    @media(min-width:860px){.svc-detail{grid-template-columns:.95fr 1.05fr}}
    .svc-media img{width:100%;height:auto;border-radius:14px;border:1px solid var(--line);box-shadow:0 20px 50px rgba(13,27,42,.12);display:block;aspect-ratio:8/7;object-fit:cover}
    .svc-media img.ph{background:linear-gradient(135deg,var(--cream),#fff);min-height:360px}
    .svc-list{list-style:none;margin-top:14px;display:flex;flex-direction:column;gap:12px}
    .svc-list li{padding-left:30px;position:relative;font-size:1rem;color:var(--ink)}
    .svc-list li::before{content:"✓";position:absolute;left:0;top:0;width:20px;height:20px;color:var(--brass);font-weight:800}
  </style>
</Base>
