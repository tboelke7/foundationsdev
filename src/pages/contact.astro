---
import Base from '../layouts/BaseLayout.astro';
import { site } from '../siteConfig.js';
---
<Base title="Contact" description="Get your free Web Presence Report Card. Graded A–F across 8 dimensions." path="/contact/">
  <section>
    <div class="wrap" style="max-width:680px">
      <p class="label">Free Web Presence Report Card</p>
      <h1 style="margin-top:12px">See exactly where you stand.</h1>
      <p style="margin-top:16px;color:var(--muted)">
        We grade your web presence A–F across 8 dimensions — site speed, Google Profile,
        reviews, mobile, SEO, and more. Free, no obligation. Fill this out and we'll send it over.
      </p>

      <div class="card hs-card" style="margin-top:32px">
        <!-- HubSpot form — portal 246368131, form c03b7a6e-540a-47dc-81c8-4f33737411c5 -->
        <div id="hubspot-report-card-form"></div>
        <script charset="utf-8" type="text/javascript" src="//js-na2.hsforms.net/forms/embed/v2.js" is:inline></script>
        <script is:inline>
          (function () {
            function loadForm() {
              if (window.hbspt && window.hbspt.forms) {
                window.hbspt.forms.create({
                  portalId: "246368131",
                  formId: "c03b7a6e-540a-47dc-81c8-4f33737411c5",
                  region: "na2",
                  target: "#hubspot-report-card-form"
                });
              } else {
                setTimeout(loadForm, 200);
              }
            }
            loadForm();
          })();
        </script>
      </div>

      <p style="margin-top:28px;text-align:center;color:var(--muted)">
        Prefer to talk? Call <a style="color:var(--brass);font-weight:700" href={`tel:${site.phoneRaw}`}>{site.phone}</a>
        or email <a style="color:var(--brass);font-weight:700" href={`mailto:${site.email}`}>{site.email}</a>
      </p>
    </div>
  </section>

  <style is:global>
    .hs-card .hs-form-field{margin-bottom:16px}
    .hs-card label{font-family:var(--body);font-weight:600;color:var(--navy);font-size:.9rem;display:block;margin-bottom:6px}
    .hs-card input[type=text],.hs-card input[type=email],.hs-card input[type=tel],.hs-card textarea,.hs-card select{
      width:100%;padding:11px 13px;border:1px solid var(--line);border-radius:8px;font-family:var(--body);font-size:1rem;background:#fff}
    .hs-card input:focus,.hs-card textarea:focus,.hs-card select:focus{outline:none;border-color:var(--gold);box-shadow:0 0 0 3px rgba(212,168,85,.18)}
    .hs-card .hs-button{background:var(--gold);color:var(--navy);font-weight:700;border:0;padding:13px 26px;border-radius:8px;font-family:var(--body);font-size:1rem;cursor:pointer;transition:.2s;width:100%}
    .hs-card .hs-button:hover{background:var(--brass);color:#fff}
    .hs-card .hs-error-msg,.hs-card .hs-error-msgs label{color:#c0392b;font-weight:500}
    .hs-card .hs-form-required{color:var(--brass)}
  </style>
</Base>
