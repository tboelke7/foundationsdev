---
import { site } from '../siteConfig.js';
import Header from '../components/Header.astro';
const { title, description, path = "" } = Astro.props;
const canonical = site.url + path;
const fullTitle = title ? `${title} | ${site.shortName}` : `${site.name} — ${site.tagline}`;
const desc = description || "Owned, fast, conversion-built web presence for Tampa Bay trades and home-service contractors.";

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": site.name,
  "image": site.url + "/images/logo.png",
  "url": site.url,
  "telephone": site.phone,
  "email": site.email,
  "address": { "@type": "PostalAddress", "addressLocality": site.city, "addressRegion": site.state, "addressCountry": "US" },
  "areaServed": site.serviceAreas.map(a => ({ "@type": "City", "name": a })),
  "slogan": site.tagline
};
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={desc} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={desc} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <!-- Self-hosted-style font load with display=swap to avoid render-blocking (PageSpeed fix) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@800&family=DM+Sans:wght@400;500;700&family=DM+Mono:wght@500&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <!-- ============ HUBSPOT TRACKING PIXEL SLOT ============ -->
 <!-- Meta Pixel Code -->
<script is:inline>
!function(f,b,e,v,n,t,s)
{if(f.fbq)return;n=f.fbq=function(){n.callMethod?
n.callMethod.apply(n,arguments):n.queue.push(arguments)};
if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
n.queue=[];t=b.createElement(e);t.async=!0;
t.src=v;s=b.getElementsByTagName(e)[0];
s.parentNode.insertBefore(t,s)}(window, document,'script',
'https://connect.facebook.net/en_US/fbevents.js');
fbq('init', '36583469651298854');
fbq('track', 'PageView');
</script>
<noscript><img height="1" width="1" style="display:none"
src="https://www.facebook.com/tr?id=36583469651298854&ev=PageView&noscript=1"
/></noscript>
<!-- End Meta Pixel Code -->
<!-- Microsoft Clarity -->
<script type="text/javascript" is:inline>
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "xhd4e5jqww");
</script>
<!-- End Microsoft Clarity -->
<!-- Google tag (GA4) -->
<script async is:inline src="https://www.googletagmanager.com/gtag/js?id=G-YCS6V7DGGZ"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-YCS6V7DGGZ');
</script>
<!-- End Google tag -->
<!-- HubSpot form submit → Meta Lead event -->
<script is:inline>
window.addEventListener('message', function(event) {
  if (event.data.type === 'hsFormCallback' && event.data.eventName === 'onFormSubmitted') {
    if (window.fbq) {
      fbq('track', 'Lead', {
        content_name: 'Web Presence Report Card'
      });
    }
  }
});
</script>
<!-- End HubSpot Lead listener -->
  <style is:global>
    :root{
      --navy:#0D1B2A; --brass:#B8893A; --gold:#D4A855; --cream:#F5F0E8;
      --ink:#0D1B2A; --muted:#5b6470; --line:#e4ddd0;
      --display:'Manrope',sans-serif; --body:'DM Sans',sans-serif; --mono:'DM Mono',monospace;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:var(--body);color:var(--ink);background:var(--cream);line-height:1.6}
    h1,h2,h3{font-family:var(--display);font-weight:800;line-height:1.1;letter-spacing:-.02em}
    h1{font-size:clamp(2.2rem,5vw,3.6rem)}
    h2{font-size:clamp(1.6rem,3.5vw,2.4rem)}
    a{color:inherit;text-decoration:none}
    .wrap{max-width:1080px;margin:0 auto;padding:0 24px}
    .label{font-family:var(--mono);text-transform:uppercase;letter-spacing:.12em;font-size:.72rem;color:var(--brass)}
    .btn{display:inline-block;background:var(--gold);color:var(--navy);font-weight:700;padding:14px 28px;border-radius:8px;transition:.2s}
    .btn:hover{background:var(--brass);color:#fff}
    .btn-ghost{background:transparent;border:1.5px solid var(--navy);color:var(--navy)}
    .btn-ghost:hover{background:var(--navy);color:var(--cream)}
    header.nav{position:sticky;top:0;z-index:50;background:var(--navy);color:var(--cream)}
    .nav .wrap{display:flex;align-items:center;justify-content:space-between;height:70px}
    .nav a.brand{font-family:var(--display);font-weight:800;font-size:1.25rem;color:var(--cream)}
    .nav nav{display:flex;gap:26px;align-items:center}
    .nav nav a{font-size:.95rem;color:var(--cream);opacity:.85}
    .nav nav a:hover{opacity:1;color:var(--gold)}
    .nav .call{background:var(--gold);color:var(--navy);padding:9px 18px;border-radius:7px;font-weight:700;opacity:1}
    section{padding:72px 0}
    footer{background:var(--navy);color:var(--cream);padding:48px 0;font-size:.92rem}
    footer a{color:var(--gold)}
    .grid{display:grid;gap:24px}
    @media(min-width:760px){.g3{grid-template-columns:repeat(3,1fr)}.g2{grid-template-columns:repeat(2,1fr)}}
    .card{background:#fff;border:1px solid var(--line);border-radius:12px;padding:28px}
    @media(max-width:760px){.nav nav a:not(.call){display:none}}

    footer{background:var(--navy);color:var(--cream);padding:56px 0 28px}
    .foot{display:grid;gap:36px;grid-template-columns:1.6fr 1fr 1fr 1.2fr}
    @media(max-width:860px){.foot{grid-template-columns:1fr 1fr}}
    @media(max-width:520px){.foot{grid-template-columns:1fr}}
    .foot-logo{height:30px;width:auto;margin-bottom:14px}
    .foot-tag{font-family:var(--mono);font-size:.72rem;letter-spacing:.06em;color:var(--gold);text-transform:uppercase}
    .foot-blurb{margin-top:12px;opacity:.78;font-size:.9rem;max-width:38ch}
    .foot-badges{display:flex;gap:8px;flex-wrap:wrap;margin-top:16px}
    .foot-badge{font-family:var(--mono);font-size:.64rem;letter-spacing:.06em;text-transform:uppercase;border:1px solid rgba(212,168,85,.4);color:var(--gold);border-radius:20px;padding:4px 10px}
    .foot-h{font-family:var(--mono);font-size:.68rem;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);margin-bottom:14px}
    .foot-col a{display:block;color:var(--cream);opacity:.82;font-size:.92rem;margin-bottom:9px}
    .foot-col a:hover{opacity:1;color:var(--gold)}
    .foot-areas{opacity:.6;font-size:.78rem;margin-top:10px;line-height:1.7}
    .foot-base{margin-top:36px;padding-top:20px;border-top:1px solid rgba(255,255,255,.1);opacity:.55;font-size:.82rem}
  </style>
</head>
<body>
  <Header />
  <main><slot /></main>
  <footer>
    <div class="wrap foot">
      <div class="foot-brand">
        <img src="/images/logo-header.webp" alt="Foundations" class="foot-logo" />
        <p class="foot-tag">{site.tagline}</p>
        <p class="foot-blurb">Owned, fast, conversion-built web presence for Tampa Bay trades and home-service contractors. You own everything we build — no markup, no hostage fees.</p>
        <div class="foot-badges">
          <span class="foot-badge">You own 100%</span>
          <span class="foot-badge">No ad markup</span>
          <span class="foot-badge">Tampa Bay</span>
        </div>
      </div>
      <div class="foot-col">
        <p class="foot-h">Services</p>
        <a href="/services/web-presence-builds/">Web Presence Builds</a>
        <a href="/services/google-business-profile/">Google Business Profile</a>
        <a href="/services/local-seo/">Local SEO</a>
        <a href="/services/lead-generation-ads/">Lead Generation</a>
        <a href="/services/social-content/">Social & Content</a>
        <a href="/services/review-generation/">Review Generation</a>
      </div>
      <div class="foot-col">
        <p class="foot-h">Company</p>
        <a href="/pricing/">Pricing</a>
        <a href="/about/">About</a>
        <a href="/blog/">Blog</a>
        <a href="/contact/">Contact</a>
      </div>
      <div class="foot-col">
        <p class="foot-h">Get in touch</p>
        <a href={`tel:${site.phoneRaw}`}>{site.phone}</a>
        <a href={`mailto:${site.email}`}>{site.email}</a>
        <p class="foot-areas">{site.serviceAreas.join(" · ")}</p>
        <a class="btn navcta" style="margin-top:14px" href="/contact/">Get Started →</a>
      </div>
    </div>
    <div class="wrap foot-base">© {new Date().getFullYear()} Foundations Business Development · {site.tagline}</div>
  </footer>
</body>
</html>
