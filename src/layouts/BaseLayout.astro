---
import { site } from '../siteConfig.js';
const { title, description, path = "" } = Astro.props;
const canonical = site.url + path;
const fullTitle = title ? `${title} | ${site.shortName}` : `${site.name} — ${site.tagline}`;
const desc = description || "Owned, fast, conversion-built web presence for Tampa Bay trades and home-service contractors.";

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": site.name,
  "image": site.url + "/images/logo.png",
  "url": site.url,
  "telephone": site.phone,
  "email": site.email,
  "address": { "@type": "PostalAddress", "addressLocality": site.city, "addressRegion": site.state, "addressCountry": "US" },
  "areaServed": site.serviceAreas.map(a => ({ "@type": "City", "name": a })),
  "slogan": site.tagline
};
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={desc} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={desc} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <!-- Self-hosted-style font load with display=swap to avoid render-blocking (PageSpeed fix) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@800&family=DM+Sans:wght@400;500;700&family=DM+Mono:wght@500&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <!-- ============ HUBSPOT TRACKING PIXEL SLOT ============ -->
  <!-- Paste your HubSpot tracking script here (portal 246368131). -->
  <!-- ===================================================== -->
  <style is:global>
    :root{
      --navy:#0D1B2A; --brass:#B8893A; --gold:#D4A855; --cream:#F5F0E8;
      --ink:#0D1B2A; --muted:#5b6470; --line:#e4ddd0;
      --display:'Manrope',sans-serif; --body:'DM Sans',sans-serif; --mono:'DM Mono',monospace;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:var(--body);color:var(--ink);background:var(--cream);line-height:1.6}
    h1,h2,h3{font-family:var(--display);font-weight:800;line-height:1.1;letter-spacing:-.02em}
    h1{font-size:clamp(2.2rem,5vw,3.6rem)}
    h2{font-size:clamp(1.6rem,3.5vw,2.4rem)}
    a{color:inherit;text-decoration:none}
    .wrap{max-width:1080px;margin:0 auto;padding:0 24px}
    .label{font-family:var(--mono);text-transform:uppercase;letter-spacing:.12em;font-size:.72rem;color:var(--brass)}
    .btn{display:inline-block;background:var(--gold);color:var(--navy);font-weight:700;padding:14px 28px;border-radius:8px;transition:.2s}
    .btn:hover{background:var(--brass);color:#fff}
    .btn-ghost{background:transparent;border:1.5px solid var(--navy);color:var(--navy)}
    .btn-ghost:hover{background:var(--navy);color:var(--cream)}
    header.nav{position:sticky;top:0;z-index:50;background:var(--navy);color:var(--cream)}
    .nav .wrap{display:flex;align-items:center;justify-content:space-between;height:70px}
    .nav a.brand{font-family:var(--display);font-weight:800;font-size:1.25rem;color:var(--cream)}
    .nav nav{display:flex;gap:26px;align-items:center}
    .nav nav a{font-size:.95rem;color:var(--cream);opacity:.85}
    .nav nav a:hover{opacity:1;color:var(--gold)}
    .nav .call{background:var(--gold);color:var(--navy);padding:9px 18px;border-radius:7px;font-weight:700;opacity:1}
    section{padding:72px 0}
    footer{background:var(--navy);color:var(--cream);padding:48px 0;font-size:.92rem}
    footer a{color:var(--gold)}
    .grid{display:grid;gap:24px}
    @media(min-width:760px){.g3{grid-template-columns:repeat(3,1fr)}.g2{grid-template-columns:repeat(2,1fr)}}
    .card{background:#fff;border:1px solid var(--line);border-radius:12px;padding:28px}
    @media(max-width:760px){.nav nav a:not(.call){display:none}}
  </style>
</head>
<body>
  <header class="nav">
    <div class="wrap">
      <a class="brand" href="/">Foundations</a>
      <nav>
        <a href="/services/">Services</a>
        <a href="/pricing/">Pricing</a>
        <a href="/about/">About</a>
        <a href="/blog/">Blog</a>
        <a class="call" href={`tel:${site.phoneRaw}`}>Call {site.phone}</a>
      </nav>
    </div>
  </header>
  <main><slot /></main>
  <footer>
    <div class="wrap">
      <strong style="font-family:var(--display);font-size:1.1rem">Foundations Business Development</strong>
      <p style="margin-top:8px;opacity:.8">{site.tagline}</p>
      <p style="margin-top:16px">
        <a href={`tel:${site.phoneRaw}`}>{site.phone}</a> &nbsp;·&nbsp;
        <a href={`mailto:${site.email}`}>{site.email}</a>
      </p>
      <p style="margin-top:8px;opacity:.6;font-size:.85rem">Serving {site.serviceAreas.join(", ")} · {site.region}, {site.state}</p>
      <p style="margin-top:20px;opacity:.5;font-size:.8rem">© {new Date().getFullYear()} Foundations Business Development. You own everything we build.</p>
    </div>
  </footer>
</body>
</html>
